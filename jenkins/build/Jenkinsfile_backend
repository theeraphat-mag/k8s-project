pipeline {
    agent any

    parameters {
        string(name: 'VERSION', defaultValue: 'latest', description: 'Image version to build and deploy')
    }

    environment {
        IMAGE_NAME = 'thamonwanfirst/monkeypop-backend'
        IMAGE_TAG = "${params.VERSION}"
    }

    triggers {
        githubPush()
    }

    stages {
        stage('1. Checkout') {
            steps {
                deleteDir()
                git credentialsId: 'github', url: 'https://github.com/theeraphat-mag/k8s-project.git', branch: 'main'
            }
        }

        stage('2. Build') {
            steps {
                echo "Stage 2: Compile & Install dependencies..."
                dir('backend') {
                    sh "npm install"
                }
            }
        }

        stage('3. Test') {
            steps {
                echo "Stage 3: Running Unit & Integration Tests..."
                dir('backend') {
                    // Simulating tests
                    sh "echo 'Testing backend components...'"
                    sh "node -v"
                    sh "echo 'Tests passed!'"
                }
            }
        }

        stage('4. Docker Build') {
            steps {
                echo "Stage 4: Building Docker image..."
                sh "docker build -t ${env.IMAGE_NAME}:${env.IMAGE_TAG} ./backend"
            }
        }

        stage('5. Push Hub') {
            steps {
                echo "Stage 5: Pushing to Docker Hub..."
                withCredentials([usernamePassword(credentialsId: 'dockerhub', usernameVariable: 'DUSER', passwordVariable: 'DPASS')]) {
                    sh 'echo $DPASS | docker login -u $DUSER --password-stdin'
                    sh "docker push ${env.IMAGE_NAME}:${env.IMAGE_TAG}"
                }
            }
        }

        stage('6. Deploy') {
            steps {
                echo "Stage 6: Triggering Terraform & Ansible..."
                
                echo "Running Terraform..."
                dir('Terraform') {
                    sh 'terraform init'
                    // Import existing resources when the cluster already has them.
                    sh 'terraform import kubernetes_namespace.monkeypop monkeypop || true'
                    sh 'terraform import kubernetes_config_map.backend_config monkeypop/backend-config || true'
                    sh 'terraform import kubernetes_secret.backend_secret monkeypop/backend-secret || true'
                    sh 'terraform import kubernetes_persistent_volume_claim.redis_pvc monkeypop/redis-pvc || true'
                    sh 'terraform import kubernetes_deployment.redis monkeypop/redis || true'
                    sh 'terraform import kubernetes_service.redis monkeypop/redis || true'
                    sh 'terraform apply -auto-approve'
                }

                echo "Running Ansible for application deployment..."
                dir('ansible/backend') {
                    sh "ansible-playbook -i hosts.ini deploy_backend.yml -e version=${env.IMAGE_TAG}"
                }

                echo "Deploying monitoring stack..."
                sh 'export KUBECONFIG=/var/jenkins_home/.kube/config; kubectl apply -f prometheus/rbac.yaml --validate=false'
                sh 'export KUBECONFIG=/var/jenkins_home/.kube/config; kubectl apply -f k8s/kube-state-metrics.yaml --validate=false'
                sh 'export KUBECONFIG=/var/jenkins_home/.kube/config; kubectl apply -f k8s/monitoring.yaml --validate=false'
                sh 'export KUBECONFIG=/var/jenkins_home/.kube/config; kubectl apply -f k8s/monitoring-deployment.yaml --validate=false'
            }
        }
    }

    post {
        always {
            sh "docker rmi ${env.IMAGE_NAME}:${env.IMAGE_TAG} || true"
            sh 'docker logout || true'
            deleteDir()
        }
    }
}

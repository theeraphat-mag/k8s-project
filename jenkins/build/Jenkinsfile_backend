pipeline {
    agent { label 'server' }

    environment {
        IMAGE_NAME = 'thamonwanfirst/monkeypop-backend'
        IMAGE_TAG = 'latest'
    }

    stages {
        stage('Checkout') {
            steps {
                cleanWs()
                git credentialsId: 'github', url: 'https://github.com/tapootum/project-03-2026.git', branch: 'main'
            }
        }

        stage('Build Docker Image') {
            steps {
                echo 'Building backend image...'
                sh "docker build -t ${env.IMAGE_NAME}:${env.IMAGE_TAG} ./backend"
            }
        }

        stage('Test Docker Image') {
            steps {
                echo 'Testing backend image...'
                sh 'docker run --rm thamonwanfirst/monkeypop-backend:latest node --version'
            }
        }

        stage('Push to Docker Hub') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'dockerhub', usernameVariable: 'DUSER', passwordVariable: 'DPASS')]) {
                    echo 'Logging in to Docker Hub...'
                    sh 'echo $DPASS | docker login -u $DUSER --password-stdin'

                    echo 'Pushing backend image to Docker Hub...'
                    sh "docker push ${env.IMAGE_NAME}:${env.IMAGE_TAG}"
                }
            }
        }
    }

    post {
        always {
            sh "docker rmi ${env.IMAGE_NAME}:${env.IMAGE_TAG} || true"
            sh 'docker logout || true'
            cleanWs()
        }
    }
}

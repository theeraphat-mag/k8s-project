pipeline {
    agent any

    parameters {
        string(name: 'VERSION', defaultValue: 'latest', description: 'Image version to build and deploy')
    }

    environment {
        IMAGE_NAME = 'thamonwanfirst/monkeypop-frontend'
        IMAGE_TAG = "${params.VERSION}"
    }

    triggers {
        githubPush()
    }

    stages {
        stage('Checkout') {
            steps {
                deleteDir()
                git credentialsId: 'github', url: 'https://github.com/theeraphat-mag/k8s-project.git', branch: 'refactor'
            }
        }

        stage('Docker Build') {
            steps {
                echo "Building and Pushing Frontend Image..."
                sh "docker build -t ${env.IMAGE_NAME}:${env.IMAGE_TAG} ./frontend"
            }
        }

        stage('Docker Push') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'dockerhub', usernameVariable: 'DUSER', passwordVariable: 'DPASS')]) {
                    sh 'echo $DPASS | docker login -u $DUSER --password-stdin'
                    sh "docker push ${env.IMAGE_NAME}:${env.IMAGE_TAG}"
                }
            }
        }

        stage('Deploy by Ansible') {
            steps {
                echo "Deploying Frontend to Kubernetes..."
                dir('ansible/frontend') {
                    sh "ansible-playbook -i hosts.ini deploy_frontend.yml -e version=${env.IMAGE_TAG}"
                }
            }
        }

        stage('Verify Deployment') {
            steps {
                echo "Verifying Frontend deployment..."
                sh 'kubectl rollout status deployment/frontend -n monkeypop --timeout=120s'
                sh 'kubectl get svc frontend -n monkeypop'
            }
        }

        stage('Cleanup') {
            steps {
                echo "Frontend pipeline cleanup completed in post block"
            }
        }
    }

    post {
        always {
            sh "docker rmi ${env.IMAGE_NAME}:${env.IMAGE_TAG} || true"
            sh 'docker logout || true'
            deleteDir()
        }
    }
}

pipeline {
    agent any

    parameters {
        string(name: 'VERSION', defaultValue: 'latest', description: 'Image version to build and deploy')
    }

    environment {
        IMAGE_NAME = 'thamonwanfirst/monkeypop-frontend'
        IMAGE_TAG = "${params.VERSION}"
    }

    triggers {
        githubPush()
    }

    stages {
        stage('1. Checkout') {
            steps {
                deleteDir()
                git credentialsId: 'github', url: 'https://github.com/theeraphat-mag/k8s-project.git', branch: 'main'
            }
        }

        stage('2. Build') {
            steps {
                echo "Stage 2: Compile & Install dependencies (Frontend)..."
                dir('frontend') {
                    // Frontend is just static files, but we follow the rubric
                    sh "echo 'Installing frontend tools...'"
                    sh "ls -lh"
                }
            }
        }

        stage('3. Test') {
            steps {
                echo "Stage 3: Running Unit & Integration Tests (Frontend)..."
                dir('frontend') {
                    sh "echo 'Checking HTML/Assets integrity...'"
                    sh "test -f index.html"
                    sh "echo 'Frontend tests passed!'"
                }
            }
        }

        stage('4. Docker Build') {
            steps {
                echo "Stage 4: Building Docker image (Frontend)..."
                sh "docker build -t ${env.IMAGE_NAME}:${env.IMAGE_TAG} ./frontend"
            }
        }

        stage('5. Push Hub') {
            steps {
                echo "Stage 5: Pushing to Docker Hub..."
                withCredentials([usernamePassword(credentialsId: 'dockerhub', usernameVariable: 'DUSER', passwordVariable: 'DPASS')]) {
                    sh 'echo $DPASS | docker login -u $DUSER --password-stdin'
                    sh "docker push ${env.IMAGE_NAME}:${env.IMAGE_TAG}"
                }
            }
        }

        stage('6. Deploy') {
            steps {
                echo "Stage 6: Triggering Ansible Deployment..."
                dir('ansible/frontend') {
                    sh "ansible-playbook -i hosts.ini deploy_frontend.yml -e version=${env.IMAGE_TAG}"
                }
            }
        }
    }

    post {
        always {
            sh "docker rmi ${env.IMAGE_NAME}:${env.IMAGE_TAG} || true"
            sh 'docker logout || true'
            deleteDir()
        }
    }
}

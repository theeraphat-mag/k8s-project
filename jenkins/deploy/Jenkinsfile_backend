pipeline {
    agent { label 'server' }

    stages {
        stage('Checkout') {
            steps {
                cleanWs()
                git credentialsId: 'github', url: 'https://github.com/theeraphat-mag/k8s-project.git', branch: 'mag'
            }
        }

        stage('Deploy to Kubernetes Cluster') {
            steps {
                echo 'Deploy backend to Kubernetes cluster...'
                sh 'cd ansible/backend && ansible-playbook -i hosts.ini deploy_backend.yml'
            }
        }
    }

    post {
        always {
            cleanWs()
        }
    }
}
